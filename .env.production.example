# ─────────────────────────────────────────────────────────────────────────────
# .env.production.example
#
# Copy to .env.production and fill in real values.
# NEVER commit .env.production to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (AWS RDS PostgreSQL or Render Postgres) ──────────────────────────
DATABASE_URL=postgresql://cuuser:STRONG_PASSWORD@your-rds-host.amazonaws.com:5432/credit_underwriting

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=replace_with_64_hex_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Storage backend ───────────────────────────────────────────────────────────
# "s3" for AWS S3 production | "minio" for local MinIO (dev only)
STORAGE_BACKEND=s3

# ── AWS credentials ───────────────────────────────────────────────────────────
# Prefer IAM Instance Roles on EC2 (leave these empty and attach an IAM role).
# Only fill in if using long-lived keys (not recommended for EC2).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket configuration
AWS_S3_BUCKET=credit-underwriting-docs
AWS_S3_REGION=ap-south-1
# AWS_S3_ENDPOINT_URL=   # Leave empty for real AWS S3

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Frontend API URL (used at Docker build time) ──────────────────────────────
REACT_APP_API_URL=https://yourdomain.com
